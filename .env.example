DB_HOST=localhost
DB_PORT=5432
DB_NAME=media_ai
DB_USER=media_user
DB_PASS=media_pass

STORAGE_PATH=./storage

MIN_FACE_CONFIDENCE=0.75
MIN_BIB_CONFIDENCE=60

# processing/batch.py concurrency — see comments there for why these defaults
# are set the way they are (OCR is CPU-bound; face embedding is capped by
# CompreFace's own UWSGI_PROCESSES/UWSGI_THREADS config below).
OCR_WORKERS=4
FACE_WORKERS=2

# Stalled-batch safety net (processing/batch.py:sweep_stalled_events) —
# catches events whose upload-portal auto-trigger never fired (e.g. the
# browser closed too early). SWEEP_GRACE_MINUTES should comfortably exceed
# how long a normal upload session takes, so it doesn't fire on sessions
# that are still legitimately in progress.
SWEEP_INTERVAL_MINUTES=15
SWEEP_GRACE_MINUTES=15
BATCH_RUN_STALE_MINUTES=60

# CompreFace (face search) — UI/API at http://localhost:8001 once docker-compose is up.
# Generate the API key from a Face Recognition service in the CompreFace admin UI.
COMPREFACE_URL=http://localhost:8001
COMPREFACE_API_KEY=

# Local dev only (Windows): set if tesseract.exe isn't on PATH.
# Not needed in Docker — tesseract-ocr is installed there via apt and is already on PATH.
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
